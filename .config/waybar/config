{
    "layer": "top",
    "position": "top",
    "height": 38,
    "margin-top": 8,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": ["custom/power", "hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "bluetooth", "network", "cpu", "memory", "battery", "pulseaudio"],

    "custom/power": {
        "format" : "‚≠ė ",
        "tooltip": false,
        "on-click": "wlogout -b 5"
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "persistent-workspaces": {
            "*": 5
        },
        "cursor": true
    },

    "hyprland/window": {
        "format": "<span color='#cba6f7' weight='bold' size='x-large'>ÔĄÖ</span> <span rise='3000'>{title}</span>",
        "max-length": 50,
        "separate-outputs": false
    },

    "tray": {
        "icon-size": 20,
        "spacing": 10,
        "cursor": true
    },

    "bluetooth": {
        "format": " ůįāĮ ",
        "format-disabled": " ůįā≤ ",
        "format-connected": " ůįāĪ ",
        "on-click": "blueman-manager"
    },

    "network": {
        "format-wifi": "Ôáę  {essid}",
        "format-ethernet": "ÓľČ  Ethernet",
        "format-linked": "ÔĀě  Linked (No IP)",
        "format-disconnected": "ÔĀĪ  Disconnected",
        "tooltip": false
    },

    "cpu": {
        "interval": 5,
        "format": "Ôčõ {usage}%",
        "states": {
            "high": 80
        },
        "tooltip": true
    },

    "memory": {
        "interval": 5,
        "format": "ÔÉČ {used:0.1f}G",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G"
    },

    "battery": {
        "states": {
            "good": 85,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-full": "{icon} {capacity}%",
        "format-plugged": "ÔÉß {capacity}%",
        "format-charging": "ÔÉß {capacity}%",
        "format-alt": "{icon} {capacity}%",
        "format-icons": ["ÔČĄ ", "ÔČÉ ", "ÔČā ", "ÔČĀ ", "ÔČÄ "],
        "tooltip-format": "{time}"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "ÔĎ¶  {volume}%",
        "format-bluetooth": "ÔäĒ {volume}%",
        "format-bluetooth-muted": "ÔĎ¶  {volume}%",
        "format-icons": {
            "headphone": "ÔÄ• ",
            "headset": "ÔÄ• ",
            "default": ["ÔÄ® "]
        },
        "on-click": "pavucontrol"
    },

    "clock": {
        "format": "{:%a %d/%m/%Y ~ %H:%M}",
        "tooltip-format": "<span size='15000'><tt>{calendar}</tt></span>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#F5C2E7'><b>{}</b></span>",
                "weekdays": "<span color='#89B4FA'><b>{}</b></span>",
                "days": "<span color='#CDD6F4'><b>{}</b></span>",
                "today": "<span color='#F9E2AF'><b>{}</b></span>"
            }
        },
        "on-click": "swaync-client -t -sw"
    }
}
